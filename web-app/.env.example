# Copy to web-app/.env for Docker Compose or local backend runs.

# Optional OpenAI-compatible local/model server. The app still works without it,
# but AI summaries will show as unavailable until this endpoint is reachable.
NEURODATA_LLM_BASE_URL=http://127.0.0.1:8001/v1
NEURODATA_LLM_MODEL=
NEURODATA_LLM_TIMEOUT=90

# Optional DANDI token for authenticated workflows.
DANDI_API_TOKEN=
DANDI_API_BASE_URL=https://api.dandiarchive.org/api

# Comma-separated origins for split frontend/backend hosting.
# Use * when serving the built frontend from the backend container.
NEURODATA_CORS_ORIGINS=*

# Persistent cache/index location.
NEURODATA_MCP_STORAGE_DIR=/data/.mcp-storage
NEURODATA_SAMPLE_DOWNLOAD_MAX_BYTES=250000000
